# ── Telegram ──────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# ── Owner & Admins ────────────────────────────────────────
OWNER_ID=your_telegram_user_id
ADMIN_IDS=

# ── MongoDB ───────────────────────────────────────────────
DB_URI=mongodb+srv://user:password@cluster.mongodb.net
DB_NAME=tmdb_poster_bot

# ── TMDB API ──────────────────────────────────────────────
# Get free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── Bot Settings ──────────────────────────────────────────
SESSION_NAME=/app/sessions/tmdb_poster_bot
PLOT_MAX_CHARS=300
API_TIMEOUT=15
KEEP_ALIVE=true
PORT=8000
